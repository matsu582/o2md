<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE components PUBLIC "-//DBFLUTE//DTD LastaDi 1.0//EN"
    "http://dbflute.org/meta/lastadi10.dtd">
<components namespace="fessCrawler">

    <!-- o2md-filter によるテキスト抽出 -->
    <component name="o2mdExtractor"
               class="org.codelibs.fess.crawler.extractor.impl.CommandExtractor">
        <property name="command">"o2md-filter $INPUT_FILE"</property>
    </component>

    <!-- 既存のTikaExtractor（o2md対象外のファイル用） -->
    <component name="tikaExtractor"
               class="org.codelibs.fess.crawler.extractor.impl.TikaExtractor"/>

    <!-- ExtractorFactory: MIMEタイプごとにExtractorを登録 -->
    <component name="extractorFactory"
               class="org.codelibs.fess.crawler.extractor.ExtractorFactory">
        <property name="extractorMap">
            <map>
                <!-- Excel -->
                <entry key="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet">
                    <ref>o2mdExtractor</ref>
                </entry>
                <entry key="application/vnd.ms-excel">
                    <ref>o2mdExtractor</ref>
                </entry>

                <!-- Word -->
                <entry key="application/vnd.openxmlformats-officedocument.wordprocessingml.document">
                    <ref>o2mdExtractor</ref>
                </entry>
                <entry key="application/msword">
                    <ref>o2mdExtractor</ref>
                </entry>

                <!-- PowerPoint -->
                <entry key="application/vnd.openxmlformats-officedocument.presentationml.presentation">
                    <ref>o2mdExtractor</ref>
                </entry>
                <entry key="application/vnd.ms-powerpoint">
                    <ref>o2mdExtractor</ref>
                </entry>

                <!-- PDF -->
                <entry key="application/pdf">
                    <ref>o2mdExtractor</ref>
                </entry>

                <!-- 画像（OCR） -->
                <entry key="image/jpeg">
                    <ref>o2mdExtractor</ref>
                </entry>
                <entry key="image/png">
                    <ref>o2mdExtractor</ref>
                </entry>
                <entry key="image/webp">
                    <ref>o2mdExtractor</ref>
                </entry>
                <entry key="image/gif">
                    <ref>o2mdExtractor</ref>
                </entry>
                <entry key="image/bmp">
                    <ref>o2mdExtractor</ref>
                </entry>
                <entry key="image/tiff">
                    <ref>o2mdExtractor</ref>
                </entry>

                <!-- その他のファイルはTikaで処理 -->
                <entry key="text/html">
                    <ref>tikaExtractor</ref>
                </entry>
                <entry key="text/plain">
                    <ref>tikaExtractor</ref>
                </entry>
                <entry key="application/xml">
                    <ref>tikaExtractor</ref>
                </entry>
            </map>
        </property>
    </component>

</components>
